{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "base_url": "__OPENAI_BASE_URL__",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.0,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "username": null,
        "owner": "rust-lang",
        "repo": "rust",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "username": null,
        "owner": "ziglang",
        "repo": "zig",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "username": null,
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "username": null,
        "owner": "floci-io",
        "repo": "floci",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "username": null,
        "owner": "charmbracelet",
        "repo": "crush",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "量子位",
        "url": "https://wechat2rss.xlab.app/feed/7131b577c61365cb47e81000738c10d872685908.xml",
        "enabled": true
      },
      {
        "name": "新智元",
        "url": "https://wechat2rss.xlab.app/feed/ede30346413ea70dbef5d485ea5cbb95cca446e7.xml",
        "enabled": true
      },
      {
        "name": "Stanford AI Lab (SAIL) Blog",
        "url": "https://ai.stanford.edu/blog/feed.xml",
        "enabled": true
      },
      {
        "name": "AI Weekly",
        "url": "https://aiweekly.co/issues.rss",
        "enabled": true
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/rss",
        "enabled": true
      },
      {
        "name": "IT HOME",
        "url": "https://www.ithome.com/rss/",
        "enabled": false
      },
      {
        "name": "GitHub Trending",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "trending"
      },
      {
        "name": "Microsoft Research",
        "url": "https://www.microsoft.com/en-us/research/feed/",
        "enabled": true
      },
      {
        "name": "Product Hunt",
        "url": "https://www.producthunt.com/feed",
        "enabled": true,
        "category": "trending"
      },
      {
        "name": "晚点",
        "url": "https://rsshub.imwolf.ink/latepost",
        "enabled": true
      },
      {
        "name": "联合早报",
        "url": "https://rsshub.imwolf.ink/zaobao/znews/world",
        "enabled": true
      },
      {
        "name": "虎嗅",
        "url": "https://rsshub.imwolf.ink/huxiu/moment",
        "enabled": true
      },
      {
        "name": "南方周末",
        "url": "https://rsshub.imwolf.ink/infzm/2",
        "enabled": true
      },
      {
        "name": "中国日报",
        "url": "https://rsshub.imwolf.ink/chinadaily/language/thelatest",
        "enabled": true
      },
      {
        "name": "InfoQ",
        "url": "https://rsshub.imwolf.ink/infoq/recommend",
        "enabled": true
      },
      {
        "name": "BBC",
        "url": "https://rsshub.imwolf.ink/bbc/chinese",
        "enabled": true
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "ProgrammingLanguages",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "生成结果: #{result}\n今日日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
